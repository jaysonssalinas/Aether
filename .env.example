# ============================================================
# AETHER — Environment Variables
# Copy this file to .env.local in each app that needs it.
# NEVER commit .env.local to git.
# ============================================================

# --- PostgreSQL (Admin app only) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aether_admin
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# --- JWT Secret (Admin app) ---
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_strong_random_secret_in_production

# --- Email (for contact form notifications) ---
# Using Resend (recommended, free tier: 3000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@aether.com.ph
EMAIL_TO_DIGITAL=jayson@aether.com.ph
EMAIL_TO_CELEBRATIONS=remlyn@aether.com.ph

# --- Sanity CMS (for content updates, optional) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_token

# --- Cross-site URLs (aether main app) ---
# In production, set these to the deployed Netlify URLs for each app
NEXT_PUBLIC_DIGITAL_URL=http://localhost:3001
NEXT_PUBLIC_CELEBRATIONS_URL=http://localhost:3002

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
